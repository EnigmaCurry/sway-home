#!/bin/bash
## Launch virt-viewer for screencasting demo VM and rename the window
VM_NAME="${1:-artix}"
DEMO_TITLE="OBS-DEMO-VM"

virt-viewer --connect qemu:///system "$VM_NAME" &
VIEWER_PID=$!

# Wait for the window to appear and rename it
for i in $(seq 1 50); do
    sleep 0.2
    CON_ID=$(swaymsg -t get_tree | jq -r ".. | select(.pid? == $VIEWER_PID) | .id" 2>/dev/null)
    if [ -n "$CON_ID" ]; then
        swaymsg "[con_id=$CON_ID] title_format $DEMO_TITLE"
        break
    fi
done

wait $VIEWER_PID
