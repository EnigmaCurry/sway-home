#!/usr/bin/env bb

;; git-drone — watch a GitHub repo for pushes; kill, pull, restart a dev command.
;;
;; Usage:
;;   git drone                          # run from inside a git repo
;;   git -C /path/to/repo drone        # specify repo via git -C
;;   git drone --branch main --cmd "npm run dev"
;;
;; Environment variables (lower priority than CLI flags):
;;   BRANCH       — branch to watch (default: current branch)
;;   DEV_CMD      — long-running dev command (default: just dev)
;;   PULL_CMD     — pull command (default: none, fetch only)
;;   GITHUB_REPO  — owner/repo (default: auto-detected from git remote)

(require '[babashka.process :as p]
         '[babashka.cli :as cli]
         '[cheshire.core :as json]
         '[clojure.java.io :as io])

;; --- CLI arg parsing ---

(def cli-spec
  {:branch  {:alias :b :desc "Branch to watch" :ref "<branch>"}
   :cmd     {:alias :c :desc "Dev command to run" :ref "<cmd>"}
   :pull    {:alias :p :desc "Pull command" :ref "<cmd>"}
   :repo    {:alias :r :desc "GitHub owner/repo" :ref "<owner/repo>"}
   :help    {:alias :h :desc "Show this help"}})

(def cli-opts (cli/parse-opts *command-line-args* {:spec cli-spec}))

(when (:help cli-opts)
  (println "Usage: git drone [options]")
  (println)
  (println "Watch a GitHub repo for pushes; kill, pull, restart a dev command.")
  (println)
  (println "Options:")
  (println (cli/format-opts {:spec cli-spec}))
  (System/exit 0))

;; --- Configuration ---

(def repo-dir
  (let [result (p/shell {:out :string :err :string :continue true}
                        "git" "rev-parse" "--show-toplevel")]
    (when-not (zero? (:exit result))
      (println "ERROR: not a git repository. Run from a repo or use git -C <path> drone")
      (System/exit 1))
    (clojure.string/trim (:out result))))

(def branch
  (or (:branch cli-opts)
      (System/getenv "BRANCH")
      (-> (p/shell {:dir repo-dir :out :string}
                    "git" "rev-parse" "--abbrev-ref" "HEAD")
          :out
          clojure.string/trim)))

(def github-repo
  (or (:repo cli-opts)
      (System/getenv "GITHUB_REPO")
      (let [url (-> (p/shell {:dir repo-dir :out :string}
                              "git" "remote" "get-url" "origin")
                    :out
                    clojure.string/trim)]
        (second (re-find #"github\.com[:/](.+?)(?:\.git)?$" url)))))

(def dev-cmd
  (or (:cmd cli-opts)
      (System/getenv "DEV_CMD")
      "just dev"))

(def pull-cmd
  (or (:pull cli-opts)
      (System/getenv "PULL_CMD")
      "echo 'No pull command configured. Set PULL_CMD to update the working tree.'"))

;; --- Process management ---

(defonce dev-process (atom nil))
(defonce running? (atom false))
(defonce pending? (atom false))

(defn kill-dev! []
  (when-let [proc @dev-process]
    (let [pid (.pid proc)]
      (println "Killing previous dev process tree (pid" pid ")...")
      ;; Kill the entire process group (setsid gives the dev command its own group)
      (p/shell {:continue true} "kill" "-TERM" "--" (str "-" pid))
      (Thread/sleep 500)
      (p/shell {:continue true} "kill" "-KILL" "--" (str "-" pid))
      (.waitFor proc)
      (reset! dev-process nil)
      (println "Previous dev process killed."))))

(defn start-dev!
  ([] (start-dev! false))
  ([fail-early?]
   (println "$" dev-cmd)
   (let [proc (-> (ProcessBuilder. ["setsid" "bash" "-c" dev-cmd])
                  (.directory (java.io.File. repo-dir))
                  (.inheritIO)
                  (.start))]
     (reset! dev-process proc)
     (println "Started dev process (pid" (.pid proc) ")")
     (when fail-early?
       (Thread/sleep 1000)
       (when-not (.isAlive proc)
         (let [exit (.exitValue proc)]
           (when-not (zero? exit)
             (println "ERROR: dev command exited immediately with code" exit)
             (System/exit exit))))))))

(defn sh! [cmd]
  (println "$" cmd)
  (p/shell {:dir repo-dir :out :inherit :err :inherit}
           "bash" "-c" cmd))

(defn handle-push! []
  (when (compare-and-set! running? false true)
    (try
      (loop []
        (reset! pending? false)
        (println "\nReceived push; stopping dev, pulling, restarting...")
        (kill-dev!)
        (sh! "git fetch origin")
        (let [sha (-> (p/shell {:dir repo-dir :out :string}
                               "git" "rev-parse" (str "origin/" branch))
                      :out
                      clojure.string/trim)]
          (println (str "origin/" branch " is at " sha)))
        (sh! pull-cmd)
        (start-dev!)

        (when @pending?
          (println "Another push arrived while restarting; repeating...")
          (recur)))
      (catch Exception e
        (binding [*out* *err*]
          (println "Command failed:" (ex-message e))))
      (finally
        (reset! running? false)))))

;; --- Webhook cleanup ---

(defn cleanup-drone-webhooks!
  "Delete any existing webhooks created by gh webhook forward (smee.io URLs)."
  []
  (println "Cleaning up stale drone webhooks...")
  (let [result (p/shell {:out :string :err :string :continue true}
                        "gh" "api" (str "repos/" github-repo "/hooks")
                        "--jq" ".[] | select(.config.url | test(\"smee.io\")) | .id")
        ids (when (zero? (:exit result))
              (->> (clojure.string/split-lines (:out result))
                   (map clojure.string/trim)
                   (remove clojure.string/blank?)))]
    (doseq [id ids]
      (println "  Deleting stale webhook" id)
      (p/shell {:out :inherit :err :inherit}
               "gh" "api" "-X" "DELETE"
               (str "repos/" github-repo "/hooks/" id)))
    (when (seq ids)
      (println "  Cleaned up" (count ids) "stale webhook(s)"))))

;; --- Main ---

(defn -main []
  (when-not github-repo
    (println "ERROR: Could not determine GitHub repo. Set GITHUB_REPO=owner/repo or use --repo")
    (System/exit 1))

  (println "git-drone")
  (println "  repo:   " repo-dir)
  (println "  github: " github-repo)
  (println "  branch: " branch)
  (println "  cmd:    " dev-cmd)
  (println "  pull:   " pull-cmd)
  (println)

  ;; Clean up stale webhooks from previous runs
  (cleanup-drone-webhooks!)

  ;; Start the dev process immediately (fail early if it exits right away)
  (start-dev! true)

  ;; Start gh webhook forward with retry on transient failures
  (let [max-retries 5
        cmd ["gh" "webhook" "forward"
             "--repo" github-repo
             "--events" "push"]
        shutdown-proc (atom nil)]

    (.addShutdownHook
     (Runtime/getRuntime)
     (Thread. (fn []
                (println "\nShutting down...")
                (kill-dev!)
                (when-let [p @shutdown-proc] (.destroyForcibly p))
                (try (cleanup-drone-webhooks!)
                     (catch Exception _ nil)))))

    (loop [attempt 1]
      (println "\n$" (clojure.string/join " " cmd))
      (let [proc (-> (ProcessBuilder. cmd)
                     (.directory (java.io.File. repo-dir))
                     (.redirectErrorStream true)
                     (.start))
            reader (io/reader (.getInputStream proc))]
        (reset! shutdown-proc proc)

        ;; Read lines from gh webhook forward stdout
        (doseq [line (line-seq reader)]
          (try
            (let [payload (json/parse-string line)]
              (when (and (map? payload)
                         (= (str "refs/heads/" branch)
                            (get payload "ref")))
                (reset! pending? true)
                (future (handle-push!))))
            (catch Exception _
              ;; Not JSON (status messages from gh), print through
              (println "[gh]" line))))

        ;; gh webhook forward exited
        (let [exit (.waitFor proc)]
          (if (and (not (zero? exit)) (< attempt max-retries))
            (let [delay (* attempt 5)]
              (println "gh webhook forward exited with code" exit
                       (str "(retry " attempt "/" max-retries " in " delay "s...)"))
              (Thread/sleep (* delay 1000))
              (recur (inc attempt)))
            (do
              (println "gh webhook forward exited with code" exit)
              (kill-dev!)
              (System/exit exit))))))))

(-main)
